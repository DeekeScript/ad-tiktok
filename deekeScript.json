{
  "name": "TikGrow",
  "icon": "logo/dke.png",
  "head": "images/robot.png",
  "host": "https://home.deeke.top",
  "switchSetting": {
    "alipay": true
  },
  "bottomMenus": [
    {
      "title": "{NAME}",
      "icon": "images/home.png",
      "banner": "images/home-top.png",
      "type": "home"
    },
    {
      "title": "话术库",
      "icon": "images/speech.png",
      "type": "speech"
    },
    {
      "title": "设置",
      "icon": "images/setting.png",
      "type": "setting"
    }
  ],
  "settingLists": [
    {
      "title": "联系客服",
      "icon": "images/kefu.png",
      "type": "customerService",
      "description": "客服微信：DeekeScript",
      "hidden": false
    },
    {
      "title": "功能说明",
      "icon": "images/manual.png",
      "type": "notice",
      "file": "task.html"
    },
    {
      "title": "智能话术",
      "icon": "images/robot-chat.png",
      "type": "settingService",
      "settingPage": {
        "params": [
          {
            "type": "switch",
            "label": "开启扣子智能AI话术",
            "value": false,
            "name": "setting_baidu_wenxin_switch"
          },
          {
            "type": "textArea",
            "label": "角色描述",
            "name": "setting_baidu_wenxin_role_text",
            "hidden": false,
            "value": "你是一个评论大师，可以对用户的标题进行犀利的评论，同时能赢得用户的好感度"
          },
          {
            "type": "text",
            "label": "access_token",
            "name": "setting_baidu_wenxin_secret",
            "value": "如：brIq133KaAPNEkn109avxl7MXUHHW0kg"
          },
          {
            "type": "text",
            "label": "bot_id",
            "name": "setting_baidu_wenxin_bot",
            "value": ""
          },
          {
            "type": "numberRange",
            "label": "超级霸屏(%)",
            "name": "setting_comment_with_photo",
            "value": 0,
            "min": 0,
            "max": 100,
            "hidden": false
          },
          {
            "type": "switch",
            "label": "私信不使用AI话术",
            "value": true,
            "name": "setting_baidu_wenxin_private_switch"
          },
          {
            "type": "numberRange",
            "label": "延迟百分比（网络延迟解决）",
            "value": 0,
            "min": 0,
            "max": 300,
            "step": 10,
            "name": "setting_slow"
          },
          {
            "type": "notice",
            "title": "* 开启后，将使用扣子平台智能体，让拓客更简单~ \n* 注意：相关设置可进入扣子平台获取",
            "textColor": "#AA0000",
            "textSize": 16
          }
        ]
      },
      "hidden": false
    },
    {
      "title": "远程控制",
      "icon": "images/group_run.png",
      "type": "settingService",
      "settingPage": {
        "params": [
          {
            "type": "switch",
            "label": "允许远程控制",
            "value": false,
            "name": "setting_group_run"
          },
          {
            "type": "numberRange",
            "label": "Http请求间隔(秒)",
            "name": "setting_group_run_second",
            "value": 10,
            "min": 1,
            "max": 300,
            "hidden": false
          },
          {
            "type": "notice",
            "title": "* 开启开关后，需要打开无障碍开关、悬浮窗开关、图色权限；并且保持软件在主界面 \n\n* 进入当前页，打开开关，返回后，即开启远程控制\n\n* 进入当前页，关闭开关，返回后，即可关闭远程控制",
            "textColor": "#AA0000",
            "textSize": 16
          }
        ]
      },
      "hidden": false
    },
    {
      "title": "数据统计",
      "icon": "images/statistics.png",
      "type": "statistics",
      "jsFile": "statistics/statistics.js"
    },
    {
      "title": "上传日志",
      "icon": "images/upload.png",
      "type": "uploadLog",
      "url": "/dke/uploadLog"
    },
    {
      "title": "系统升级",
      "icon": "images/system-update.png",
      "type": "updateApp",
      "url": "/dke/updateApp"
    },
    {
      "title": "清理数据",
      "icon": "images/clear.png",
      "description": "确定清理嘛？",
      "type": "clear"
    }
  ],
  "apis": [
    {
      "type": "bind",
      "url": "/dke/login"
    },
    {
      "type": "checkBind",
      "url": "/dke/checkBind"
    },
    {
      "type": "aiSpeechToken",
      "url": "/dke/getBaiduToken"
    },
    {
      "type": "config",
      "url": "/dkee/config"
    },
    {
      "type": "getToken",
      "url": "/alipay/getToken"
    },
    {
      "type": "createOrder",
      "url": "/alipay/createOrder"
    }
